@import './reset'
.error-msg {
	bottom(-16px)
	font-size(10px)
	font-color(#f56c6c)
}
.mine-table-title {
	position(relative)
	padding-t-b(10px)
	padding-l-r(15px)
	background(#f2f2f2)
	line-height(22px)
	font-weight(550)
	border-top-left-radius: 4px
	border-top-right-radius: 4px
	&:before {
		content: ''
		position(absolute)
		top(0)
		bottom(0)
		left(0)
		width(4px)
		border-top-left-radius: 4px
		background(#42b983)
	}
}
.like-table {
	margin-bottom(0)
	border: 1px solid #e6e6e6
	border-bottom-left-radius: 4px
	border-bottom-right-radius: 4px
	li {
		height(38px)
		div {
			padding-l-r(8px)
			height(38px)
			line-height(38px)
			&.ltl-label {
				width(120px)
				border-right: 1px solid #e6e6e6
			}
			&.ltl-cont {}
		}
		&:not(:last-child) {
			border-bottom: 1px solid #e6e6e6
		}
		&:hover {
			background(#f2f2f2)
		}
	}
}